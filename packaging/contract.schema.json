{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scoop-extras-fork/package-contract.schema.json",
  "title": "No-admin package contract",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "priority",
    "candidate_status",
    "source_policy",
    "installer",
    "no_admin",
    "targets",
    "duplicate_lookup",
    "ci",
    "track",
    "readiness"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": ["string", "null"]
    },
    "priority": {
      "enum": ["requested", "high-signal", "audit-only"]
    },
    "candidate_status": {
      "enum": ["candidate", "blocked", "covered", "deferred"]
    },
    "source_policy": {
      "type": "object",
      "required": ["public_url_required", "local_files_are_evidence_only"],
      "properties": {
        "public_url_required": {
          "type": "boolean"
        },
        "local_files_are_evidence_only": {
          "type": "boolean"
        }
      }
    },
    "installer": {
      "type": "object",
      "required": ["type", "evidence"],
      "properties": {
        "type": {
          "enum": ["nsis", "msi", "inno", "zip", "portable", "unknown"]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "no_admin": {
      "type": "object",
      "required": ["required", "strategy", "hard_blockers"],
      "properties": {
        "required": {
          "const": true
        },
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "hard_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "targets": {
      "type": "object",
      "required": ["scoop", "chocolatey"],
      "properties": {
        "scoop": {
          "type": "object",
          "required": ["status", "expected_manifest", "no_admin_strategy"],
          "properties": {
            "status": {
              "enum": ["candidate", "implemented", "covered", "blocked", "deferred"]
            },
            "expected_manifest": {
              "type": ["string", "null"]
            },
            "no_admin_strategy": {
              "type": "string"
            }
          }
        },
        "chocolatey": {
          "type": "object",
          "required": ["status", "package_id", "no_admin_strategy"],
          "properties": {
            "status": {
              "enum": ["candidate", "implemented", "covered", "blocked", "deferred"]
            },
            "package_id": {
              "type": ["string", "null"]
            },
            "no_admin_strategy": {
              "type": "string"
            }
          }
        }
      }
    },
    "duplicate_lookup": {
      "type": "object",
      "required": ["scoop_terms", "chocolatey_terms", "winget_terms"],
      "properties": {
        "scoop_terms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "chocolatey_terms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "winget_terms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ci": {
      "type": "object",
      "required": ["require_contract", "require_duplicate_lookup", "require_no_admin_evidence"],
      "properties": {
        "require_contract": {
          "const": true
        },
        "require_duplicate_lookup": {
          "type": "boolean"
        },
        "require_no_admin_evidence": {
          "type": "boolean"
        }
      }
    },
    "track": {
      "type": "string",
      "pattern": "^conductor/tracks/[A-Za-z0-9_\\-]+/$"
    },
    "readiness": {
      "type": "object",
      "required": [
        "state",
        "runtime_validation",
        "hardening_report",
        "smoke_report",
        "last_reviewed",
        "decision"
      ],
      "properties": {
        "state": {
          "enum": [
            "blocked",
            "covered",
            "implemented",
            "deferred",
            "candidate-requires-runtime-validation"
          ]
        },
        "runtime_validation": {
          "enum": ["passed", "blocked", "deferred", "not-run", "not-required"]
        },
        "hardening_report": {
          "type": "string",
          "pattern": "^packaging/reports/[a-z0-9][a-z0-9-]*-hardening\\.md$"
        },
        "smoke_report": {
          "type": "string",
          "pattern": "^packaging/reports/[a-z0-9][a-z0-9-]*-noadmin-smoke\\.md$"
        },
        "last_reviewed": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": true
}
