    <licenseUrl>https://www.tightvnc.com/licensing.php</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Viewer-only TightVNC client for connecting to VNC servers.</description>
    <summary>TightVNC Viewer no-admin extraction-only package candidate.</summary>
    <tags>tightvnc vnc viewer remote-control no-admin</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
