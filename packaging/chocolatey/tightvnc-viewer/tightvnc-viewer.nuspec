<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>tightvnc-viewer</id>
    <version>2.8.87</version>
    <packageSourceUrl>https://github.com/edithatogo/Extras</packageSourceUrl>
    <owners>edithatogo</owners>
    <title>TightVNC Viewer</title>
    <authors>GlavSoft LLC</authors>
